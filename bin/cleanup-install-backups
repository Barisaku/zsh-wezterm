#!/usr/bin/env sh
set -eu

# Remove backup files generated by install.sh.
# The installer creates files like:
#   ~/.zshrc.backup.YYYYMMDD-HHMMSS
#   ~/.config/starship.toml.backup.YYYYMMDD-HHMMSS
#   ~/bin/ssh-prod.backup.YYYYMMDD-HHMMSS

HOME_DIR=${HOME:?HOME is not set}
DRY_RUN=1
FORCE=0
MAX_DEPTH=4

usage() {
  cat <<'EOF'
Usage:
  cleanup-install-backups [options]

Options:
  --force        Actually delete backup files. Without this, only list targets.
  --dry-run      List targets without deleting. This is the default.
  --max-depth N  find(1) max depth under $HOME. Default: 4.
  -h, --help     Show this help.

Targets:
  Files under $HOME matching:
    *.backup.YYYYMMDD-HHMMSS

Examples:
  cleanup-install-backups
  cleanup-install-backups --force
  cleanup-install-backups --max-depth 6
EOF
}

log() {
  printf '%s\n' "$*"
}

backup_find() {
  find "$HOME_DIR" -maxdepth "$MAX_DEPTH" \
    -type f \
    -name '*.backup.[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]' \
    -print 2>/dev/null
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --force)
      FORCE=1
      DRY_RUN=0
      ;;
    --dry-run)
      DRY_RUN=1
      FORCE=0
      ;;
    --max-depth)
      MAX_DEPTH="${2:-}"
      case "$MAX_DEPTH" in
        ''|*[!0-9]*)
          log "Invalid --max-depth value: $MAX_DEPTH" >&2
          exit 2
          ;;
      esac
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      log "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

tmp_file=$(mktemp "${TMPDIR:-/tmp}/cleanup-install-backups.XXXXXX")
trap 'rm -f "$tmp_file"' EXIT HUP INT TERM

backup_find | sort > "$tmp_file"

count=$(wc -l < "$tmp_file" | tr -d ' ')

if [ "$count" -eq 0 ]; then
  log "No install.sh backup files found."
  exit 0
fi

log "Found $count install.sh backup file(s):"
sed 's/^/  /' "$tmp_file"

if command -v du >/dev/null 2>&1; then
  log ""
  log "Approx size:"
  if command -v xargs >/dev/null 2>&1; then
    tr '\n' '\0' < "$tmp_file" | xargs -0 du -ch 2>/dev/null | tail -n 1 || true
  else
    log "  xargs is not available; skipping size summary."
  fi
fi

if [ "$DRY_RUN" -eq 1 ]; then
  log ""
  log "Dry-run only. Re-run with --force to delete these files."
  exit 0
fi

if [ "$FORCE" -ne 1 ]; then
  log "Refusing to delete without --force." >&2
  exit 2
fi

log ""
log "Deleting..."
while IFS= read -r file; do
  [ -n "$file" ] || continue
  rm -f -- "$file"
  log "Deleted: $file"
done < "$tmp_file"

log "Done."
